# LLM Provider — switch without any code changes
# Options: groq | ollama | anthropic
LLM_PROVIDER=groq
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# API keys (only the one matching LLM_PROVIDER is needed)
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Notion integration
# NOTION_AUTH_MODE=internal  → user pastes their own token (default, no setup needed)
# NOTION_AUTH_MODE=oauth     → full OAuth flow (Day 2)
NOTION_AUTH_MODE=internal
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/auth/notion/callback

# App
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
