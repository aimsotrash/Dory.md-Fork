# ── LLM Provider ─────────────────────────────────────────────────────────────
# Switch between providers by changing these two lines — no code changes needed.
#
#   groq      → Groq cloud API. Fast, generous free tier. Requires GROQ_API_KEY.
#   ollama    → Local Ollama server (Qwen, Gemma). No API key needed.
#   anthropic → Anthropic cloud API (Claude). Requires ANTHROPIC_API_KEY.
#
LLM_PROVIDER=groq

# Model name for the chosen provider:
#   groq examples:      llama-3.3-70b-versatile (default) | llama-3.1-8b-instant | gemma2-9b-it | qwen-qwq-32b
#   ollama examples:    qwen2.5:7b | gemma3:4b | llama3.2:3b
#   anthropic examples: claude-haiku-4-5-20251001 | claude-sonnet-4-6
LLM_MODEL=llama-3.3-70b-versatile

# Groq API key (only used when LLM_PROVIDER=groq)
GROQ_API_KEY=

# Ollama server URL (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Anthropic API key (only used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# ── Notion Integration ────────────────────────────────────────────────────────
# Mode: internal | oauth
#   internal → user pastes their own Notion integration token (build first)
#   oauth    → full consent flow (add during Day 2 polish)
NOTION_AUTH_MODE=internal
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/auth/notion/callback

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_random_32_byte_hex_string

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
